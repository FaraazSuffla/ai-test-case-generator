# AI Test Case Generator — Environment Variables
# Copy this file to .env and add your key.
#
# You only need ONE key. Anthropic (Claude) is the default.
# Demo mode works without any key at all — try it first!
#
# Get keys:
#   Anthropic → https://console.anthropic.com  (free trial available)
#   OpenAI    → https://platform.openai.com/api-keys

# Default provider (recommended)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Only needed if using --provider openai
OPENAI_API_KEY=your-openai-key-here
